# ---- Telegram (три бота: WMS, Lupa, Rubik — PLAN_UNIFIED_MAX_BOT_APPEND п. 11) ----
TELEGRAM_TOKEN=your_telegram_bot_token
# Совместимость с the_bot_on_dute: 0 — полностью отключить Telegram сервис и доставку в TG
# USED_TELEGRAMM=0
# TELEGRAM_TOKEN_WMS=
# TELEGRAM_TOKEN_LUPA=
# TELEGRAM_TOKEN_RUBIK=

# ---- MAX (один токен на весь support-бот) ----
# MAX_BOT_TOKEN=your_max_bot_token
# MAX_TOKEN=your_max_bot_token

# ---- Админка ----
# Telegram: user_id из @userinfobot (через запятую, если несколько)
ADMIN_IDS=472518684
# Telegram: роль «Системный администратор СТЦ» (раздел «СА СТЦ»)
# STC_SA_IDS=472518684
# MAX: user_id в мессенджере MAX — кнопка «Админ-панель» в главном меню (через запятую)
# ADMIN_MAX_IDS=188357485
# MAX: роль «Системный администратор СТЦ»
# STC_SA_MAX_IDS=188357485
# MAX: после рестарта игнорировать входящие события, пока не придёт новая команда (/start и т.п.)
# MAX_REQUIRE_FRESH_COMMAND_AFTER_RESTART=1
# MAX: авто-разблокировка после рестарта, даже если новая команда не дошла (секунды)
# MAX_FRESH_COMMAND_WAIT_SECONDS=30
# MAX: retry отправки сообщений с вложениями при attachment.not.ready
# MAX_ATTACHMENT_SEND_RETRIES=30
# MAX_ATTACHMENT_SEND_RETRY_DELAY_SECONDS=1.0
# Уведомления «новая задача для СА СТЦ»: только в будни 08:00–17:00 МСК; вне окна — в очередь до 08:00 след. рабочего дня (файл data/stc_assign_notify_queue.json)
# STC_NOTIFY_BUSINESS_HOURS=1
# STC_NOTIFY_TZ=Europe/Moscow
# STC_NOTIFY_HOUR_START=8
# STC_NOTIFY_HOUR_END=17

# ---- Jira (общие) ----
JIRA_LOGIN_URL=https://jira.petrovich.tech
