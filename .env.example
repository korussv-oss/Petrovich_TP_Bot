# ---- Прочее (интервалы, логи, шифрование) ----
# PASSWORD_STATUS_CHECK_INTERVAL=90
# COMMENTS_CHECK_INTERVAL=20
# Молчаливая синхронизация при last_comment_count=0 и несвежей привязке только если публичных комментариев >= N (антиволна после сбоя state)
# COMMENTS_ZERO_BASELINE_SKIP_MIN=8
# Порог «подозрительного всплеска» новых комментариев за один цикл (антиспам при сбое baseline)
# COMMENTS_WAVE_DELTA_THRESHOLD=20
# Сколько id уведомлённых комментариев хранить на заявку (дедуп при повторной доставке)
# COMMENTS_NOTIFIED_IDS_CAP=400
# ANTISPAM_COOLDOWN=0.5
# LOG_LEVEL=INFO
# ENCRYPT_USER_DATA=0
# USER_DATA_ENCRYPTION_KEY=

# ---- TicketWizard (поэтапное включение, по одному сценарию) ----
# Рекомендованный порядок включения:
# 1) WMS issue → 2) WMS settings → 3) WMS PSI user → 4) Lupa search → 5) PC → 6) Orgtech → 7) Peripheral → 8) Network → 9) Electronic queue
# 10) Email OWA → 11) Email forwarding → 12) Email groups
#
# Включать ровно ОДИН флаг за раз, проверять в TG/MAX, и только потом включать следующий.
#
# TICKET_WIZARD_WMS_ISSUE=0
# TICKET_WIZARD_WMS_SETTINGS=0
# TICKET_WIZARD_WMS_PSI_USER=0
# TICKET_WIZARD_LUPA_SEARCH=0
# TICKET_WIZARD_PC_PROBLEM=0
# TICKET_WIZARD_ORGTECH_PROBLEM=0
# TICKET_WIZARD_PERIPHERAL_EQUIPMENT=0
# TICKET_WIZARD_NETWORK_PROBLEM=0
# TICKET_WIZARD_ELECTRONIC_QUEUE=0
# TICKET_WIZARD_EMAIL_OWA=0
# TICKET_WIZARD_EMAIL_FORWARDING=0
# TICKET_WIZARD_EMAIL_GROUPS=0
