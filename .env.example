# ---- Telegram (три бота: WMS, Lupa, Rubik — PLAN_UNIFIED_MAX_BOT_APPEND п. 11) ----
TELEGRAM_TOKEN=your_telegram_bot_token
# Совместимость с the_bot_on_dute: 0 — полностью отключить Telegram сервис и доставку в TG
#USED_TELEGRAMM=0
# Приоритет MAX над Telegram для связанных аккаунтов (MAX↔TG):
# - 1: если MAX привязан, уведомления идут только в MAX (и MAX будет первым)
# - 0: поведение как раньше (в оба канала)
# PREFER_MAX_CHANNEL=1
# DELIVER_TO_BOTH_CHANNELS=0
# ONLY_MAX_NOTIFICATIONS=1
# Автоочистка реестра привязок, если Jira стабильно отвечает HTTP 404/401
# COMMENTS_CLEANUP_ERROR_STREAK_THRESHOLD=5
# COMMENTS_CLEANUP_ERROR_STREAK_WINDOW_HOURS=12
# COMMENTS_CLEANUP_ERROR_STATUSES=404,401


# ---- MAX (один токен на весь support-бот) ----
# MAX_BOT_TOKEN=your_max_bot_token
# MAX_TOKEN=your_max_bot_token

# ---- Админка ----
# Telegram: user_id из @userinfobot (через запятую, если несколько)
ADMIN_IDS=472518684
# Telegram: роль «Системный администратор СТЦ» (раздел «СА СТЦ»)
# STC_SA_IDS=472518684
# MAX: user_id в мессенджере MAX — кнопка «Админ-панель» в главном меню (через запятую)
# ADMIN_MAX_IDS=188357485
# MAX: роль «Системный администратор СТЦ»
# STC_SA_MAX_IDS=188357485
# MAX: после рестарта игнорировать входящие события, пока не придёт новая команда (/start и т.п.)
# MAX_REQUIRE_FRESH_COMMAND_AFTER_RESTART=1
# MAX: авто-разблокировка после рестарта, даже если новая команда не дошла (секунды)
# MAX_FRESH_COMMAND_WAIT_SECONDS=30
# MAX: retry отправки сообщений с вложениями при attachment.not.ready
# MAX_ATTACHMENT_SEND_RETRIES=30
# MAX_ATTACHMENT_SEND_RETRY_DELAY_SECONDS=1.0
# Уведомления «новая задача для СА СТЦ»: только в будни 08:00–17:00 МСК; вне окна — в очередь до 08:00 след. рабочего дня (файл data/stc_assign_notify_queue.json)
# STC_NOTIFY_BUSINESS_HOURS=1
# STC_NOTIFY_TZ=Europe/Moscow
# STC_NOTIFY_HOUR_START=8
# STC_NOTIFY_HOUR_END=17

# ---- Jira (общие) ----
JIRA_LOGIN_URL=https://jira.petrovich.tech
JIRA_TOKEN=your_jira_api_token
# JIRA_USERNAME=
# JIRA_PASSWORD=

# ---- SQLite (производительность) ----
# Таймаут ожидания блокировок SQLite (PRAGMA busy_timeout), мс
# SQLITE_BUSY_TIMEOUT_MS=5000
# Авточекпоинт WAL (PRAGMA wal_autocheckpoint), страниц
# SQLITE_WAL_AUTOCHECKPOINT_PAGES=1000
# Держать temp таблицы/сортировки в RAM (PRAGMA temp_store=MEMORY)
# SQLITE_TEMP_STORE_MEMORY=1
# Размер кэша страниц (PRAGMA cache_size). Отрицательное число = KB (например -65536 = 64MB)
# SQLITE_CACHE_SIZE=-65536

# ---- Jira AA (Rubik: смена пароля) ----
JIRA_AA_PROJECT_KEY=AA
JIRA_AA_ISSUE_TYPE=Задача
JIRA_AA_ISSUE_TYPE_ID=10401
JIRA_AA_ASSIGNEE_USERNAME=Robot_Scripts_PS
JIRA_AA_SERVICE_DESK_ID=23
JIRA_AA_REQUEST_TYPE_ID=964
JIRA_AA_FIELD_CUSTOMER_REQUEST_TYPE=customfield_10500
JIRA_AA_REQUEST_TYPE_VALUE=Смена пароля
JIRA_AA_FIELD_AD_ACCOUNT=customfield_XXXXX
JIRA_AA_FIELD_EXISTING_PHONE=customfield_XXXXX
JIRA_AA_FIELD_PASSWORD_NEW=customfield_XXXXX
JIRA_AA_FIELD_DEPARTMENT=customfield_11406

# JSM «Чат-бот по базам знаний» (AA), пример задачи AA-83271 — подставьте requestTypeId и id полей из Jira
# Список id типов запросов: python scripts/list_jsm_request_types.py
# или с фильтром по названию: python scripts/list_jsm_request_types.py база
# JIRA_AA_KB_CHATBOT_SERVICE_DESK_ID=23
# JIRA_AA_KB_CHATBOT_REQUEST_TYPE_ID=
# JIRA_AA_KB_CHATBOT_SUMMARY=Чат-бот по базам знаний
# Поля (если авто-поиск по имени не сработает): JIRA_AA_KB_CHATBOT_FIELD_FULL_NAME, FIELD_POSITION, FIELD_AA_CHATBOT, FIELD_REQUEST_TYPE_SELECT
# Пример AA / request type 609: чекбокс «Чат-бот по базам знаний» = customfield_18717, опция «Нужно» (value 20158)
# JIRA_AA_KB_CHATBOT_FIELD_AA_CHATBOT=customfield_18717
# Несколько вариантов customfield для «AA Edit Type (office|out|STC)» — через запятую, первое совпадение с полями типа запроса:
# JIRA_AA_KB_CHATBOT_FIELD_EDIT_TYPE_CANDIDATES=customfield_XXX,customfield_YYY
# Подписи опций в Jira (как в форме):
# AA Chatbot — чекбокс «Нужно» (по умолчанию в коде = Нужно, см. AA-83271)
# JIRA_AA_KB_CHATBOT_AA_CHATBOT_OPTION_LABEL=Нужно
# JIRA_AA_KB_CHATBOT_REQUEST_TYPE_OPTION_LABEL=
# JIRA_AA_KB_CHATBOT_EDIT_OPTION_CREATE=Создать
# JIRA_AA_KB_CHATBOT_EDIT_OPTION_EDIT=Редактировать

# JSM «Доступ к корпоративной почте через браузер» (AA), пример AA-83381 — тот же portal request type, что и чат-бот, но другой чекбокс и при необходимости другая опция «Тип запроса»
# По умолчанию desk/request type и поля ФИО/должность/AA Edit Type наследуются из JIRA_AA_KB_CHATBOT_*; переопределите при расхождении.
# JIRA_AA_MAIL_BROWSER_SERVICE_DESK_ID=
# JIRA_AA_MAIL_BROWSER_REQUEST_TYPE_ID=
# JIRA_AA_MAIL_BROWSER_SUMMARY=Доступ к корпоративной почте через браузер
# Чекбокс «Доступ к корпоративной почте через браузер» (пример: customfield_14307), опция «Нужно»
# JIRA_AA_MAIL_BROWSER_FIELD_MAIL_BROWSER=customfield_14307
# JIRA_AA_MAIL_BROWSER_MAIL_OPTION_LABEL=Нужно
# Если в форме есть select «Тип запроса» — укажите label из validValues JSM для ветки почты (может отличаться от JIRA_AA_KB_CHATBOT_REQUEST_TYPE_OPTION_LABEL)
# JIRA_AA_MAIL_BROWSER_REQUEST_TYPE_OPTION_LABEL=
# JIRA_AA_MAIL_BROWSER_FIELD_FULL_NAME=
# JIRA_AA_MAIL_BROWSER_FIELD_POSITION=
# JIRA_AA_MAIL_BROWSER_FIELD_EDIT_TYPE_CANDIDATES=
# JIRA_AA_MAIL_BROWSER_FIELD_REQUEST_TYPE_SELECT=
# JIRA_AA_MAIL_BROWSER_EDIT_OPTION_CREATE=Создать
# JIRA_AA_MAIL_BROWSER_EDIT_OPTION_EDIT=Редактировать

# JSM «Учетная запись для входа на ПК» (AA), пример AA-83385 — поле AA AD Edit type (Копировать права / Разблокировать / Группа безопасности)
# По умолчанию desk/request type и часть полей наследуются от JIRA_AA_MAIL_BROWSER_*; задайте свой request type при необходимости.
# JIRA_AA_PC_ACCOUNT_SERVICE_DESK_ID=
# JIRA_AA_PC_ACCOUNT_REQUEST_TYPE_ID=
# JIRA_AA_PC_ACCOUNT_SUMMARY=Учетная запись для входа на ПК
# Поле select «AA AD Edit type» — через запятую customfield_*, иначе авто-поиск по имени поля в JSM
# JIRA_AA_PC_ACCOUNT_FIELD_AD_EDIT_TYPE_CANDIDATES=
# Текстовые поля: с кого копировать (логин), имя группы безопасности — при необходимости укажите customfield явно
# JIRA_AA_PC_ACCOUNT_FIELD_COPY_SOURCE=
# JIRA_AA_PC_ACCOUNT_FIELD_SECURITY_GROUP=
# Чекбокс сервиса «Учетная запись для входа на ПК» (обязателен на общем request type; иначе 400 «не выбран ни один сервис»)
# Если авто-поиск не сработал — задайте явно: JIRA_AA_PC_ACCOUNT_FIELD_PC_ACCOUNT=customfield_XXXXX
# JIRA_AA_PC_ACCOUNT_FIELD_PC_ACCOUNT=
# Подпись опции чекбокса в Jira (часто «Нужно», как у почты/чат-бота)
# JIRA_AA_PC_ACCOUNT_PC_OPTION_LABEL=Нужно
# JIRA_AA_PC_ACCOUNT_REQUEST_TYPE_OPTION_LABEL=
# JIRA_AA_PC_ACCOUNT_FIELD_FULL_NAME=
# JIRA_AA_PC_ACCOUNT_FIELD_POSITION=
# JIRA_AA_PC_ACCOUNT_FIELD_REQUEST_TYPE_SELECT=
# Подписи опций в боте (должны совпадать с Jira validValues для AA AD Edit type)
# JIRA_AA_PC_ACCOUNT_ACTION_COPY=Копировать права
# JIRA_AA_PC_ACCOUNT_ACTION_UNLOCK=Разблокировать учетную запись
# JIRA_AA_PC_ACCOUNT_ACTION_GROUP=Дать доступ к группе безопасности

